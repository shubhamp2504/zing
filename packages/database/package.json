{
  "name": "@zing/database",
  "version": "1.0.0",
  "description": "ZING Database — Prisma schema, client, and seed scripts",
  "main": "./index.ts",
  "types": "./index.ts",
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx seed.ts",
    "db:seed:extended": "tsx seed-extended.ts",
    "db:seed:relations": "tsx seed-relations.ts",
    "db:seed:relations:extended": "tsx seed-relations-extended.ts",
    "db:seed:all": "tsx seed.ts && tsx seed-extended.ts && tsx seed-relations.ts && tsx seed-relations-extended.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0"
  },
  "devDependencies": {
    "prisma": "^5.14.0",
    "tsx": "^4.10.0",
    "typescript": "^5.4.0"
  }
}
