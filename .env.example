# ═══════════════════════════════════════════════════════════
# ZING — Environment Variables Template
# Copy to .env.local and fill in the values
# ═══════════════════════════════════════════════════════════

# ─── DATABASE (REQUIRED) ───────────────────────────────────
# PostgreSQL connection strings
# Get from: Vercel Postgres, Neon, Supabase, or Railway

DATABASE_URL="postgresql://user:password@host:5432/zing"
DATABASE_URL_UNPOOLED="postgresql://user:password@host:5432/zing?pgbouncer=true"

# ─── AI PROVIDERS (REQUIRED FOR AI FEATURES) ───────────────
# Groq: FREE — 6000 tokens/min → https://console.groq.com
GROQ_API_KEY="gsk_..."

# Gemini: FREE — 15 requests/min → https://aistudio.google.com
GEMINI_API_KEY="AIza..."

# Claude (OPTIONAL — only if you have API access)
ANTHROPIC_API_KEY=""

# ─── SEARCH (REQUIRED FOR SEARCH FEATURES) ─────────────────
# Meilisearch: FREE cloud tier → https://cloud.meilisearch.com
MEILISEARCH_HOST="https://ms-xxxxxx.meilisearch.io"
MEILISEARCH_API_KEY="..."

# ─── CACHE (OPTIONAL — RECOMMENDED) ────────────────────────
# Upstash Redis: FREE 10K commands/day → https://console.upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── AUTHENTICATION (REQUIRED FOR ADMIN PANEL) ─────────────
# NextAuth.js configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate_with_openssl_rand_-base64_32"

# Google OAuth (for user login)
# Get from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── ANALYTICS (OPTIONAL) ──────────────────────────────────
# PostHog: FREE self-hosted or cloud → https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Sentry: FREE 5K errors/month → https://sentry.io
SENTRY_DSN=""

# ─── STORAGE (OPTIONAL — FOR IMAGE UPLOADS) ────────────────
# Cloudflare R2 (S3-compatible, FREE 10GB)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="zing-assets"

# ─── EMAIL (OPTIONAL — FOR NOTIFICATIONS) ──────────────────
# Resend: FREE 100 emails/day → https://resend.com
RESEND_API_KEY=""

# ─── PAYMENTS (FOR VIDYARTHI SUBSCRIPTION) ─────────────────
# Razorpay (Indian payment gateway)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# ─── SECURITY (OPTIONAL — RECOMMENDED) ─────────────────────
# Arcjet: FREE rate limiting → https://arcjet.com
ARCJET_KEY=""

# ─── APP CONFIGURATION ─────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_ENV="development"

# Admin emails (comma-separated)
ADMIN_EMAILS="your@email.com"

# ═══════════════════════════════════════════════════════════
# QUICK START GUIDE
# ═══════════════════════════════════════════════════════════
#
# 1. Copy this file:
#    cp .env.example .env.local
#
# 2. Fill in at minimum:
#    - DATABASE_URL (required)
#    - GROQ_API_KEY (free, instant)
#    - GEMINI_API_KEY (free, instant)
#
# 3. Initialize database:
#    npx prisma generate
#    npx prisma migrate dev
#    npx prisma db seed
#
# 4. Run dev server:
#    npm run dev
#
# 5. Open http://localhost:3000
#
# ═══════════════════════════════════════════════════════════
